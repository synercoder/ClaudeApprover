<?xml version="1.0" encoding="utf-8"?>
<Project>
  
  <PropertyGroup>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>Synercoding.ClaudeApprover</PackageId>
    <Product>Synercoding.ClaudeApprover</Product>
    <Title>Synercoding.ClaudeApprover</Title>
    <Description>Contains classes with which you can create a dotnet claude approver for the PreToolUse hook.</Description>
    <PackageTags>Claude</PackageTags>
    <PackageReleaseNotes>Added support for additional directories in InsideProjectAllowedApprover. Allows file and bash operations in directories outside the project root via the AdditionalDirectories property or by importing from Claude settings files (.claude/settings.json and .claude/settings.local.json).</PackageReleaseNotes>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
